# CMS Puppeteer Test Configuration

# Application URLs
CMS_FRONTEND_URL=http://localhost:3000
CMS_BACKEND_URL=http://localhost:8080

# Test Settings
TEST_HEADLESS=false
TEST_TIMEOUT=30000
TEST_VIEWPORT_WIDTH=1920
TEST_VIEWPORT_HEIGHT=1080

# Continuous Testing
CONTINUOUS_DURATION=300
CONTINUOUS_MIN_WAIT=2000
CONTINUOUS_MAX_WAIT=7000

# Screenshot Settings
SCREENSHOT_ENABLED=true
SCREENSHOT_FULL_PAGE=true

# Test Data
TEST_IMAGE_NAME=test-image.png
TEST_TITLE=Automated Test Image
TEST_DESCRIPTION=Image uploaded by automated testing script

# Monitoring
MONITOR_CONSOLE=true
MONITOR_NETWORK=true
MONITOR_ERRORS=true

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=1000